# Copy to .env and fill in real values. .env is gitignored.
# Spring Boot reads these automatically (via spring-dotenv).

# ───── Required in production ─────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/damkemon?retryWrites=true&w=majority
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ───── Recommended ─────
SERVER_PORT=8080
BROWSER_ENABLED=true                          # set false on hosts without Chromium

# ───── Scraper tuning ─────
SCRAPER_TIMEOUT_MS=15000
SCRAPER_RETRIES=2
SCRAPER_RETRY_DELAY=800
SCRAPER_REQUEST_DELAY=600

# ───── Playwright browser ─────
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=25000
BROWSER_WAIT_UNTIL=DOMCONTENTLOADED            # DOMCONTENTLOADED | NETWORKIDLE | LOAD

# ───── Daily price-history snapshot ─────
PRICE_HISTORY_ENABLED=true
PRICE_HISTORY_CRON=0 0 3 * * *                 # 03:00 server time, daily
